{
  "name": "tracksync",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "pnpm --filter backend test && pnpm --filter desktop test",
    "dev": "node scripts/dev-all.mjs",
    "setup": "docker compose up -d && pnpm db:push && pnpm db:seed",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:backend": "pnpm --filter backend dev",
    "dev:desktop": "pnpm --filter desktop dev",
    "dev:landing": "pnpm --filter landing dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter backend exec prisma generate",
    "db:push": "pnpm --filter backend exec prisma db push",
    "db:seed": "pnpm --filter backend exec npx tsx scripts/seed.ts",
    "rebuild:desktop": "pnpm --filter desktop exec electron-rebuild -f -w better-sqlite3-multiple-ciphers,uiohook-napi,keytar",
    "desktop:pack:win": "pnpm rebuild:desktop && pnpm --filter desktop run pack:win",
    "desktop:pack:win:x64": "pnpm rebuild:desktop && pnpm --filter desktop run pack:win:x64",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "kill-port": "^2.0.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "tailwindcss": "^3.4.0",
      "next": "14.2.35",
      "lucide-react": "0.577.0"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
