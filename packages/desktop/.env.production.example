# Production desktop — use in GitHub Environment "production" (vars), or copy to `.env.production`
# in this folder and run `pnpm --filter desktop run pack:win` (Windows) from the repo root after
# `pnpm rebuild:desktop`. Values are baked into the main process at build time.

VITE_API_URL=https://api.tracksync.dev
VITE_LANDING_URL=https://tracksync.dev

# AUTO_UPDATE_BASE_URL is no longer needed — electron-builder uses the GitHub provider
# baked into app-update.yml. Remove this line or leave it commented out.

# SENTRY_DSN=

# Asana OAuth — required when any org uses work_platform=asana.
# Create an app at https://app.asana.com/0/my-apps and add
# tracksync://oauth/asana/callback as a redirect URI.
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
# ASANA_REDIRECT_URI=tracksync://oauth/asana/callback
