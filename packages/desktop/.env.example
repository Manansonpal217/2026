# Backend API used for auth, sessions, and screenshot sync. Must match the running API (same as web NEXT_PUBLIC_API_URL host).
# VITE_API_URL=http://localhost:3001

# Landing site (Next.js). "View Online" opens /myhome/<your user id> here. Production: https://tracksync.dev
# VITE_LANDING_URL=http://localhost:3002

ATLASSIAN_CLIENT_ID=your_client_id_here
ATLASSIAN_CLIENT_SECRET=your_client_secret_here
# Callback URL - choose one:
# Production (via tracksync.dev landing page):
ATLASSIAN_REDIRECT_URI=https://tracksync.dev/oauth/callback
# Local testing with landing page (run: cd packages/landing && npm run dev):
# ATLASSIAN_REDIRECT_URI=http://localhost:3002/oauth/callback
# Local testing with built-in server (no landing page needed):
# ATLASSIAN_REDIRECT_URI=http://localhost:8080/oauth/callback
