# Staging desktop — use these values in GitHub Environment "staging" (vars) or export before build.
# Must match staging web: same API as NEXT_PUBLIC_API_URL and landing origin as NEXTAUTH_URL.

VITE_API_URL=https://api-staging.example.com
VITE_LANDING_URL=https://app-staging.example.com

# Separate auto-update feed for staging testers (public URL serving electron-builder latest.yml).
AUTO_UPDATE_BASE_URL=https://releases.example.com/tracksync-desktop-staging

