# Staging desktop — use these values in GitHub Environment "staging" (vars) or export before build.
# Must match staging web: same API as NEXT_PUBLIC_API_URL and landing origin as NEXTAUTH_URL.

VITE_API_URL=https://api-staging.tracksync.dev
VITE_LANDING_URL=https://staging.tracksync.dev

# Staging builds publish to a separate GitHub Release tag (e.g. desktop-v1.0.0-staging).
# AUTO_UPDATE_BASE_URL is not required — GitHub provider config is baked in by electron-builder.

# SENTRY_DSN=
