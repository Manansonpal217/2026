# Backend API (browser + server)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-only API base for NextAuth credentials/refresh (optional; falls back to NEXT_PUBLIC_API_URL)
NEXTAUTH_API_URL=http://localhost:3001

# NextAuth — MUST match the origin where you open the landing app (sign-in/sign-out redirects).
# Local dev: `pnpm dev` in this package uses port 3002 → keep this in sync.
NEXTAUTH_URL=http://localhost:3002

# Required in production (server will not start securely without it). Dev: omit only if using built-in fallback (see lib/next-auth-secret.ts).
NEXTAUTH_SECRET=your-random-32-char-secret-here

# Optional alias for NEXTAUTH_SECRET (NextAuth v5-style)
# AUTH_SECRET=

# Shared cookie domain (production only — enables session sharing with app.tracksync.dev)
# COOKIE_DOMAIN=.tracksync.dev

# Platform /admin (landing): grant access by setting User.is_platform_admin = true in the database
# (e.g. demo seed sets this for admin@demo.com). Requires backend migration user_is_platform_admin.
