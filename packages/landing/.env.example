# Staging / production: .env.staging.example and .env.production.example — see docs/DEPLOYMENT.md
#
# Backend API (browser + server). Must match the running backend port; if wrong or the API is down,
# authenticated requests return 401 and the app signs you out (see lib/api.ts).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-only API base for NextAuth credentials/refresh (optional; falls back to NEXT_PUBLIC_API_URL)
NEXTAUTH_API_URL=http://localhost:3001

# NextAuth — MUST match the exact origin you open in the browser (scheme + host + port).
# Mismatch causes broken session/callback behavior. Local: `pnpm dev` in this package uses 3002.
NEXTAUTH_URL=http://localhost:3002

# Required in production (server will not start securely without it). Dev: omit only if using built-in fallback (see lib/next-auth-secret.ts).
NEXTAUTH_SECRET=your-random-32-char-secret-here

# Optional alias for NEXTAUTH_SECRET (NextAuth v5-style)
# AUTH_SECRET=

# Shared cookie domain — production only (e.g. session sharing across subdomains).
# Do NOT set on localhost; a production-style value here will break auth cookies during local dev.
# COOKIE_DOMAIN=.tracksync.dev

# Platform /admin (landing): grant access by setting User.is_platform_admin = true in the database
# (e.g. demo seed sets this for admin@demo.com). Requires backend migration user_is_platform_admin.
