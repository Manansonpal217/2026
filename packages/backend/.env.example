# Must match the database you open in pgweb / GUI tools. Prisma table for screenshots is "Screenshot" (quoted).
# Phase 1 single Postgres: add ?connection_limit=10 (or similar) to cap Prisma pool size per process.
# With PgBouncer (Phase 4+), point DATABASE_URL at the pooler (transaction mode) and tune limits per RUNBOOK.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/tracksync_dev?connection_limit=10"
# Optional read replica (Phase 2+): Prisma uses this where reads are routed (see db-read.ts).
# DATABASE_READ_URL="postgresql://postgres:postgres@localhost:5433/tracksync_dev?connection_limit=5"
REDIS_URL="redis://localhost:6380"
PORT=3001
# Browser-facing app URL used in outbound emails (verify, invites, password reset). Match your landing origin (e.g. http://localhost:3002 when landing dev server is on 3002).
APP_URL="http://localhost:3002"

# Screenshots: desktop calls POST /v1/screenshots/upload-url which presigns a PUT to this bucket.
# Without valid credentials and bucket, presign fails and rows are not created.
#
# AWS S3:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_SCREENSHOT_BUCKET=tracksync-screenshots
#
# Cloudflare R2 (S3-compatible):
# S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_REGION=auto
# AWS_ACCESS_KEY_ID=   # R2 API token access key
# AWS_SECRET_ACCESS_KEY=   # R2 API token secret
# S3_SCREENSHOT_BUCKET=your-bucket-name
# S3_FORCE_PATH_STYLE=true   # optional, default true when S3_ENDPOINT set
#
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
S3_SCREENSHOT_BUCKET=tracksync-screenshots
# S3_ENDPOINT=   # set for R2
# KMS_SCREENSHOT_KEY_ID=   # AWS only; R2 does not support KMS

# JWT Keys — run `pnpm generate-keys` and add output to .env.
# In production (NODE_ENV=production), both MUST be set or the server will not start.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Optional Sentry for backend errors (production).
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# Required in production when not using AWS KMS for integration/MFA crypto (see lib/integrations/kms.ts).
# Use: openssl rand -hex 32
# DB_ENCRYPTION_KEY=

# Email / SMTP (leave empty in dev to log emails to console)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="noreply@tracksync.io"

# Landing /admin (platform): set User.is_platform_admin = true in DB for trusted accounts.
# Demo seed grants this to admin@demo.com. Production: run SQL or a controlled migration.
