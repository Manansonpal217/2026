DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tracksync_dev"
REDIS_URL="redis://localhost:6379"
PORT=3001
APP_URL="http://localhost:3000"

# JWT Keys (leave empty in dev to auto-generate ephemeral keys)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Email / SMTP (leave empty in dev to log emails to console)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="noreply@tracksync.io"
