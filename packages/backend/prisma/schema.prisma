generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum OrgPlan {
  TRIAL
  FREE
  STANDARD
  PROFESSIONAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InviteRole {
  ADMIN
  MANAGER
  EMPLOYEE
  VIEWER
}

enum TeamRole {
  LEAD
  MEMBER
}

enum OfflineTimeStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum OfflineTimeSource {
  REQUEST
  DIRECT_ADD
}

enum ProductivityType {
  PRODUCTIVE
  NEUTRAL
  UNPRODUCTIVE
}

enum NotificationType {
  OFFLINE_TIME_SUBMITTED
  OFFLINE_TIME_APPROVED
  OFFLINE_TIME_REJECTED
  OFFLINE_TIME_EXPIRED
  OFFLINE_TIME_ALREADY_RESOLVED
  PAYMENT_DUE
}

model Organization {
  id             String    @id @default(uuid())
  name           String
  slug           String    @unique
  plan           OrgPlan   @default(TRIAL)
  status         OrgStatus @default(ACTIVE)
  data_region    String    @default("us-east-1")
  trial_ends_at  DateTime?
  trial_expired  Boolean   @default(false)
  /// IANA timezone for org-wide scheduled jobs (e.g. email crons)
  timezone       String    @default("UTC")
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  users        User[]
  org_settings OrgSettings?
  invites      Invite[]
  projects     Project[]
  integrations Integration[]
  audit_logs   AuditLog[]
  offline_times OfflineTime[]
  agent_tokens       AgentToken[]
  agent_commands     AgentCommand[]
  agent_heartbeat    AgentHeartbeat?
  jira_issues        JiraIssue[]
  teams              Team[]
  work_schedules     WorkSchedule[]
  productivity_rules ProductivityRule[]
  user_rates         UserRate[]
}

model OrgSettings {
  id                          String  @id @default(uuid())
  org_id                      String  @unique
  screenshot_interval_seconds  Int     @default(60)
  screenshot_retention_days    Int     @default(30)
  blur_screenshots             Boolean @default(false)
  activity_weight_keyboard     Float   @default(0.5)
  activity_weight_mouse       Float   @default(0.3)
  activity_weight_movement    Float   @default(0.2)
  track_keyboard              Boolean @default(true)
  track_mouse                 Boolean @default(true)
  track_app_usage             Boolean @default(true)
  track_url                   Boolean @default(false)
  time_approval_required       Boolean @default(false)
  idle_detection_enabled       Boolean @default(true)
  idle_timeout_minutes         Int     @default(5)
  /// Derived from minutes (10s activity polls); default matches 5 min.
  idle_timeout_intervals       Int     @default(30)
  // Expected tracked time per calendar day for progress fill (minutes); default 8h.
  expected_daily_work_minutes  Int     @default(480)
  // When true, employees may add their own offline time unless overridden per-user.
  allow_employee_offline_time  Boolean @default(false)
  // Agent / Jira sync preferences (JSON arrays of strings or objects as needed)
  jira_projects               Json     @default("[]")
  jira_issue_types            Json     @default("[]")
  jira_statuses               Json     @default("[]")
  jira_time_logging_method    String   @default("jira_worklog")
  /// Desktop / client hint: none | asana | jira_cloud | jira_self_hosted
  work_platform               String   @default("jira_cloud")

  organization Organization @relation(fields: [org_id], references: [id])
}

model User {
  id               String     @id @default(uuid())
  org_id           String?
  email            String
  password_hash    String
  role             UserRole   @default(EMPLOYEE)
  role_version     Int        @default(0)
  /// Optional line manager; null = unassigned. Same org enforced in app layer.
  manager_id       String?
  name             String
  timezone         String     @default("UTC")
  status           UserStatus @default(ACTIVE)
  is_platform_admin Boolean   @default(false)
  // null = follow OrgSettings.allow_employee_offline_time; true/false = override
  can_add_offline_time Boolean?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  organization    Organization?  @relation(fields: [org_id], references: [id])
  manager         User?          @relation("UserHierarchy", fields: [manager_id], references: [id], onDelete: SetNull)
  direct_reports  User[]         @relation("UserHierarchy")
  refresh_tokens  RefreshToken[]
  time_sessions   TimeSession[]
  screenshots     Screenshot[]
  activity_logs   ActivityLog[]
  audit_logs      AuditLog[]
  assigned_tasks  Task[]          @relation("AssignedTasks")
  offline_times         OfflineTime[]           @relation("UserOfflineTime")
  requested_offline_times OfflineTime[]         @relation("RequestedByOfflineTime")
  approved_offline_times  OfflineTime[]         @relation("ApprovedOfflineTime")
  settings_overrides    UserSettingsOverride[]
  streak                Streak?
  notifications         Notification[]
  agent_commands      AgentCommand[]
  invites_sent        Invite[]       @relation("InvitedBy")
  managed_teams       Team[]         @relation("TeamManager")
  team_memberships    TeamMember[]
  work_schedules      WorkSchedule[]
  user_rates          UserRate[]

  @@unique([email, org_id])
  @@index([org_id])
  @@index([org_id, status])
  @@index([email])
  @@index([manager_id])
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String   @unique
  device_id  String?
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([user_id, expires_at])
}

model Invite {
  id             String     @id @default(uuid())
  org_id         String
  email          String
  role           InviteRole @default(EMPLOYEE)
  invited_by_id  String
  token          String     @unique @default(uuid())
  accepted_at    DateTime?
  expires_at     DateTime
  created_at     DateTime   @default(now())

  organization Organization @relation(fields: [org_id], references: [id])
  invited_by   User         @relation("InvitedBy", fields: [invited_by_id], references: [id])

  @@index([org_id])
  @@index([email, org_id])
  @@index([org_id, accepted_at, expires_at])
}

model Project {
  id           String   @id @default(uuid())
  org_id       String
  name         String
  color        String   @default("#6366f1")
  archived     Boolean  @default(false)
  is_billable  Boolean  @default(false)
  budget_hours Float?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  organization  Organization  @relation(fields: [org_id], references: [id])
  tasks         Task[]
  time_sessions TimeSession[]

  @@index([org_id])
  @@index([org_id, archived])
}

model Task {
  id               String   @id @default(uuid())
  project_id       String
  org_id           String
  name             String
  status           String   @default("open")
  external_id      String?
  assignee_user_id String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  project       Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee      User?         @relation("AssignedTasks", fields: [assignee_user_id], references: [id])
  time_sessions TimeSession[]

  @@index([project_id])
  @@index([project_id, status])
  @@index([org_id])
  @@index([assignee_user_id])
}

model TimeSession {
  id              String    @id @default(uuid())
  user_id         String
  org_id          String
  project_id      String?
  task_id         String?
  device_id       String
  device_name     String
  started_at      DateTime
  ended_at        DateTime?
  duration_sec    Int       @default(0)
  is_manual       Boolean        @default(false)
  notes           String?
  approval_status ApprovalStatus @default(PENDING)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user           User           @relation(fields: [user_id], references: [id])
  project        Project?       @relation(fields: [project_id], references: [id])
  task           Task?          @relation(fields: [task_id], references: [id])
  screenshots    Screenshot[]
  activity_logs  ActivityLog[]
  time_deductions SessionTimeDeduction[]

  @@unique([user_id, device_id, started_at])
  @@index([user_id, started_at])
  @@index([org_id, started_at])
  @@index([project_id, started_at])
}

model Screenshot {
  id                    String    @id @default(uuid())
  session_id            String
  user_id               String
  org_id                String
  s3_key                String    @unique
  thumb_s3_key          String?   @unique
  taken_at              DateTime
  activity_score        Float     @default(0)
  is_blurred            Boolean   @default(false)
  file_size_bytes       Int       @default(0)
  thumb_file_size_bytes Int       @default(0)
  deleted_at            DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  session TimeSession @relation(fields: [session_id], references: [id])
  user    User        @relation(fields: [user_id], references: [id])

  @@index([user_id, taken_at])
  @@index([org_id, taken_at])
  @@index([session_id])
  @@index([org_id, deleted_at, taken_at])
}

// Wall-clock ranges excluded from reported session time (e.g. after screenshot delete).
model SessionTimeDeduction {
  id          String   @id @default(uuid())
  org_id      String
  session_id  String
  range_start DateTime
  range_end   DateTime
  reason      String   @default("screenshot_deleted")
  created_at  DateTime @default(now())

  session TimeSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([org_id, session_id])
}

model Integration {
  id           String    @id @default(uuid())
  org_id       String
  type         String
  name         String
  status       String    @default("active")
  auth_data    Bytes
  kms_key_id   String
  config       Json      @default("{}")
  last_sync_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  organization Organization @relation(fields: [org_id], references: [id])
  oauth_states OAuthState[]

  @@index([org_id])
  @@index([org_id, type])
}

model OAuthState {
  id              String    @id @default(uuid())
  integration_id  String?
  org_id          String
  state           String    @unique @default(uuid())
  provider        String
  redirect_uri    String
  code_verifier   String?   // PKCE: stored for token exchange
  used            Boolean   @default(false)
  expires_at      DateTime
  created_at      DateTime  @default(now())

  integration Integration? @relation(fields: [integration_id], references: [id])

  @@index([state])
  @@index([org_id])
}

model AuditLog {
  id          String   @id @default(uuid())
  org_id      String
  actor_id    String
  action      String
  target_type String
  target_id   String
  old_value   Json?
  new_value   Json?
  ip_address  String?
  created_at  DateTime @default(now())

  actor        User         @relation(fields: [actor_id], references: [id])
  organization Organization @relation(fields: [org_id], references: [id])

  @@index([org_id, created_at])
  @@index([actor_id])
}

model ActivityLog {
  id                String   @id @default(uuid())
  session_id        String
  user_id           String
  org_id            String
  window_start      DateTime
  window_end        DateTime
  keyboard_events   Int      @default(0)
  mouse_clicks      Int      @default(0)
  mouse_distance_px Int      @default(0)
  active_app        String?
  active_url        String?
  activity_score    Float    @default(0)
  created_at        DateTime @default(now())

  session TimeSession @relation(fields: [session_id], references: [id])
  user    User        @relation(fields: [user_id], references: [id])

  @@index([user_id, window_start])
  @@index([session_id])
  @@index([org_id, window_start])
}

model OfflineTime {
  id               String            @id @default(uuid())
  org_id           String
  user_id          String
  requested_by_id  String
  approver_id      String?
  source           OfflineTimeSource @default(REQUEST)
  status           OfflineTimeStatus @default(PENDING)
  start_time       DateTime
  end_time         DateTime
  description      String
  approver_note    String?
  expires_at       DateTime?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  organization Organization @relation(fields: [org_id], references: [id])
  user         User         @relation("UserOfflineTime", fields: [user_id], references: [id])
  requested_by User         @relation("RequestedByOfflineTime", fields: [requested_by_id], references: [id])
  approver     User?        @relation("ApprovedOfflineTime", fields: [approver_id], references: [id])

  @@index([org_id, user_id, start_time])
  @@index([org_id, status])
  @@index([status, expires_at])
}

model UserSettingsOverride {
  id          String @id @default(uuid())
  org_id      String
  user_id     String
  feature_key String @db.VarChar(100)
  value       String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([org_id, user_id, feature_key])
  @@index([org_id, user_id])
}

model Streak {
  user_id          String    @id
  current_streak   Int       @default(0)
  longest_streak   Int       @default(0)
  last_active_date DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String           @id @default(uuid())
  org_id     String
  user_id    String
  type       NotificationType
  payload    Json
  read_at    DateTime?
  created_at DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read_at, created_at])
  @@index([org_id, created_at])
}

model AgentToken {
  id           String       @id @default(uuid())
  org_id       String
  token_hash   String       @unique
  name         String?
  last_seen_at DateTime?
  created_at   DateTime     @default(now())

  organization Organization @relation(fields: [org_id], references: [id])

  @@index([org_id])
}

model AgentCommand {
  id           String    @id @default(uuid())
  org_id       String
  user_id      String
  type         String
  status       String    @default("pending")
  payload      Json
  attempts     Int       @default(0)
  error        String?
  locked_at    DateTime?
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  organization Organization @relation(fields: [org_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  @@index([org_id, status])
  @@index([org_id, created_at])
  @@index([status, locked_at])
}

model AgentHeartbeat {
  id              String   @id @default(uuid())
  org_id          String   @unique
  agent_version   String?
  status          String   @default("online")
  last_seen_at    DateTime @default(now())
  last_sync_at    DateTime?
  last_sync_count Int?

  organization Organization @relation(fields: [org_id], references: [id])
}

model JiraIssue {
  id              String    @id @default(uuid())
  org_id          String
  jira_id         String
  key             String
  summary         String?
  status          String?
  assignee_email  String?
  priority        String?
  due_date        DateTime?
  labels                String[]  @default([])
  original_estimate_sec Int?
  story_points          Float?
  raw_payload           Json
  synced_at             DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  organization Organization @relation(fields: [org_id], references: [id])

  @@unique([org_id, jira_id])
  @@index([org_id])
  @@index([org_id, assignee_email])
}

model Team {
  id          String    @id @default(cuid())
  org_id      String
  name        String
  manager_id  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  organization Organization @relation(fields: [org_id], references: [id])
  manager      User?        @relation("TeamManager", fields: [manager_id], references: [id])
  members      TeamMember[]

  @@index([org_id])
  @@index([manager_id])
}

model TeamMember {
  id        String   @id @default(cuid())
  team_id   String
  user_id   String
  team_role TeamRole @default(MEMBER)
  joined_at DateTime @default(now())

  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@index([user_id])
}

model WorkSchedule {
  id          String   @id @default(cuid())
  org_id      String
  user_id     String?
  days_of_week Int[]   // 0=Sun … 6=Sat
  start_time  String   // "HH:MM"
  end_time    String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  organization Organization @relation(fields: [org_id], references: [id])
  user         User?        @relation(fields: [user_id], references: [id])

  @@index([org_id])
  @@index([org_id, user_id])
}

model ProductivityRule {
  id         String           @id @default(cuid())
  org_id     String
  pattern    String
  type       ProductivityType
  created_at DateTime         @default(now())

  organization Organization @relation(fields: [org_id], references: [id])

  @@index([org_id])
}

model UserRate {
  id             String    @id @default(cuid())
  org_id         String
  user_id        String
  rate_per_hour  Decimal   @db.Decimal(10, 2)
  currency       String    @default("INR")
  effective_from DateTime
  effective_to   DateTime?
  created_at     DateTime  @default(now())

  organization Organization @relation(fields: [org_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  @@index([org_id])
  @@index([org_id, user_id])
}
