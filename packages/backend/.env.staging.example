# Staging backend — copy to your secrets manager / server env; do not commit real values.
# Replace placeholders with your staging URLs and credentials.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tracksync_staging?connection_limit=10&sslmode=require"
REDIS_URL="redis://:PASSWORD@staging-redis:6379"
PORT=3001

# Staging landing origin (emails, invite links must match what users open in the browser).
APP_URL="https://app-staging.example.com"

# S3 or R2 — use a dedicated staging bucket
AWS_REGION=us-east-1
S3_SCREENSHOT_BUCKET=tracksync-screenshots-staging
# S3_ENDPOINT=   # R2: https://<account>.r2.cloudflarestorage.com

# JWT — generate with: pnpm --filter backend run generate-keys (use a pair unique to staging)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Optional
# SENTRY_DSN=
# DB_ENCRYPTION_KEY=   # openssl rand -hex 32 — unique per environment

RESEND_API_KEY=
# RESEND_FROM="TrackSync Staging <staging-notify@example.com>"
