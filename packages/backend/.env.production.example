# Production backend environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to /opt/tracksync/.env on the DigitalOcean droplet.
# Replace every REQUIRED_CHANGE value before starting the server.
# Never commit real values — this file contains only the template.
#
# See docs/DEPLOY_DIGITALOCEAN.md for the full setup guide.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001
APP_VERSION=0.1.0

# ── Database ──────────────────────────────────────────────────────────────────
# Phase 1 — Postgres in Docker on the same droplet.
# The hostname "postgres" resolves inside the Docker Compose network.
# REQUIRED_CHANGE: set a strong password (e.g. openssl rand -base64 32).
# This password must also be set as POSTGRES_PASSWORD in docker-compose.yml.
DATABASE_URL="postgresql://postgres:REQUIRED_CHANGE@postgres:5432/tracksync_prod?connection_limit=10"

# Phase 2 — DO Managed PostgreSQL (uncomment and remove Phase 1 line above):
# DATABASE_URL="postgresql://doadmin:REQUIRED_CHANGE@your-db-host.db.ondigitalocean.com:25060/tracksync_prod?sslmode=require&connection_limit=10"

# Optional read replica (Phase 2+):
# DATABASE_READ_URL="postgresql://doadmin:REQUIRED_CHANGE@your-read-replica.db.ondigitalocean.com:25060/tracksync_prod?sslmode=require&connection_limit=5"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Phase 1 — Redis in Docker on the same droplet.
REDIS_URL="redis://redis:6379"

# Phase 2 — DO Managed Redis (uncomment and remove Phase 1 line above):
# Note: rediss:// (double-s) = TLS, required by DO Managed Redis.
# REDIS_URL="rediss://default:REQUIRED_CHANGE@your-redis-host.db.ondigitalocean.com:25061"

# ── App URL ───────────────────────────────────────────────────────────────────
# Controls CORS (only this origin is allowed in production) and links in outbound emails.
# Must exactly match your Vercel frontend URL. No trailing slash.
APP_URL="https://tracksync.dev"

# ── Cloudflare R2 (screenshots) ───────────────────────────────────────────────
# S3-compatible storage. The desktop client calls /v1/screenshots/upload-url
# which returns a presigned PUT URL for direct upload to R2.
#
# How to get these values:
#   - Account ID:        Cloudflare Dashboard → top-right of R2 page
#   - Access Key/Secret: R2 → Manage R2 API Tokens → Create API Token
#                        (Object Read & Write on bucket tracksync-screenshots-prod)
S3_ENDPOINT="https://REQUIRED_CHANGE.r2.cloudflarestorage.com"
AWS_REGION="auto"
AWS_ACCESS_KEY_ID="REQUIRED_CHANGE"
AWS_SECRET_ACCESS_KEY="REQUIRED_CHANGE"
S3_SCREENSHOT_BUCKET="tracksync-screenshots-prod"
S3_FORCE_PATH_STYLE="true"
# KMS_SCREENSHOT_KEY_ID is AWS-only — leave unset for R2.

# ── JWT (RS256 key pair) ──────────────────────────────────────────────────────
# Generate on your local machine: pnpm --filter backend run generate-keys
# Paste as single-line values with \n between PEM lines (no literal newlines here).
# Example encoding:  awk 'NF {printf "%s\\n", $0}' private.pem
# In production (NODE_ENV=production), both keys are REQUIRED — server will not start without them.
JWT_PRIVATE_KEY="REQUIRED_CHANGE"
JWT_PUBLIC_KEY="REQUIRED_CHANGE"

# ── DB Encryption ─────────────────────────────────────────────────────────────
# Used to encrypt MFA secrets and integration OAuth tokens stored in PostgreSQL.
# REQUIRED in production. Generate: openssl rand -hex 32
DB_ENCRYPTION_KEY="REQUIRED_CHANGE"

# ── Email — Resend ────────────────────────────────────────────────────────────
# Transactional email (verify-email, password-reset, invites, report delivery).
# Sign up at resend.com, verify your domain, create an API key.
RESEND_API_KEY="REQUIRED_CHANGE"
# Optional: override the From header (must match a domain verified in Resend).
# RESEND_FROM="TrackSync <support@tracksync.dev>"

# ── Chromium — PDF export BullMQ worker ───────────────────────────────────────
# The pdfExportWorker uses Puppeteer + Chromium.
# Install on the droplet: apt-get install -y chromium-browser
CHROMIUM_PATH=/usr/bin/chromium-browser

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# Backend error tracking. Leave commented out to disable.
# SENTRY_DSN=https://REQUIRED_CHANGE@REQUIRED_CHANGE.ingest.sentry.io/REQUIRED_CHANGE

# ── Jira / Asana OAuth (optional) ────────────────────────────────────────────
# Only required if you enable Jira or Asana project integrations for your orgs.
# Register OAuth apps at:
#   Jira:  developer.atlassian.com → OAuth 2.0
#   Asana: developers.asana.com → My Apps → OAuth
# JIRA_CLIENT_ID=REQUIRED_CHANGE
# JIRA_CLIENT_SECRET=REQUIRED_CHANGE
# ASANA_CLIENT_ID=REQUIRED_CHANGE
# ASANA_CLIENT_SECRET=REQUIRED_CHANGE

# ── SSRF allowlist (integrations) ────────────────────────────────────────────
# Default covers Atlassian + Asana. Extend if you add more integrations.
# SSRF_ALLOWED_HOSTS=auth.atlassian.com,api.atlassian.com,app.asana.com,api.asana.com
