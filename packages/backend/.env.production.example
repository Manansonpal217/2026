# Production backend — copy to your secrets manager / server env; do not commit real values.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tracksync_production?connection_limit=10&sslmode=require"
REDIS_URL="redis://:PASSWORD@production-redis:6379"
PORT=3001

APP_URL="https://app.example.com"

AWS_REGION=us-east-1
S3_SCREENSHOT_BUCKET=tracksync-screenshots-production
# S3_ENDPOINT=

# JWT — unique key pair for production only (rotate via your runbook)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Required in production when not using AWS KMS for integration/MFA crypto
# DB_ENCRYPTION_KEY=

# SENTRY_DSN=https://...@....ingest.sentry.io/...

RESEND_API_KEY=
# RESEND_FROM="TrackSync <support@example.com>"
